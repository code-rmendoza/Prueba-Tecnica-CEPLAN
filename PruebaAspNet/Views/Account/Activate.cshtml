@model PruebaAspNet.ViewModels.ActivateViewModel
@{
    ViewData["Title"] = "Activar Cuenta";
    Layout = "_LoginLayout";
}

<div class="login-container">
    <div class="login-content animate-fade-in">
        <div class="login-card">
            <div class="login-form-section">
                <h2 class="mb-4 text-center" style="font-family: var(--font-display); font-weight: 700; font-size: 24px; color: var(--color-text-dark);">
                    Activar Cuenta
                </h2>
                
                <div class="doc-type-toggle">
                    <div class="btn-group w-100" role="group" aria-label="Tipo de documento">
                        <input type="radio" class="btn-check" name="TipoDocumento" id="tipoDNI" value="DNI" checked autocomplete="off">
                        <label class="btn btn-doc-type active" for="tipoDNI">DNI</label>

                        <input type="radio" class="btn-check" name="TipoDocumento" id="tipoCE" value="CE" autocomplete="off">
                        <label class="btn btn-doc-type" for="tipoCE">CE</label>
                    </div>
                </div>

                <form asp-action="Activate" asp-controller="Account" method="post" id="activateForm" novalidate>
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="TipoDocumento" id="tipoDocumentoHidden" value="DNI" />

                    <div class="form-group-custom">
                        <label asp-for="NumeroDocumento" class="form-label-custom">Número de Documento</label>
                        <div class="input-group-custom">
                            <div class="input-icon-left" style="display: flex; align-items: center; justify-content: center;">
                                <img src="/images/icon-user.png" alt="User Icon" style="width: 20px; height: 20px;" />
                            </div>
                            <input asp-for="NumeroDocumento"
                                   class="form-control-custom"
                                   placeholder="Ingresar número de documento"
                                   autocomplete="off"
                                   id="inputDocumento" />
                        </div>
                        <span asp-validation-for="NumeroDocumento" class="field-validation-custom"></span>
                    </div>

                    <button type="submit" class="btn-login" id="btnActivate">
                        <span class="btn-login-text">Activar Cuenta</span>
                        <span class="btn-login-spinner d-none">
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            Validando...
                        </span>
                    </button>
                    
                    <div class="text-center mt-3">
                        <a href="/Account/Login" style="color: #006DDB; font-weight: 500; text-decoration: none; font-size: 14px;">
                            Volver al Inicio de Sesión
                        </a>
                    </div>
                </form>
            </div>
        </div>
        
        <div class="login-help-section w-100">
            <div class="help-icon" style="display: flex; align-items: center; justify-content: center; width: 48px; height: 48px;">
                <img src="/images/support-headset.svg" alt="Support Help" style="width: 48px; height: 48px;" />
            </div>
            <p class="help-text">
                <span class="help-text-normal" style="color: #515D68;">¿Necesita ayuda?, </span>
                <a href="#" class="help-text-link" style="color: #006DDB; font-weight: 500;">contacte con el área de soporte</a>.
            </p>
        </div>
    </div>
</div>

<!-- Toast container - para errores del servidor -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" id="toastContainer"></div>

@if (TempData["ActivateError"] != null)
{
    <div id="activateToastData"
         data-message="@TempData["ActivateError"]"
         data-type="danger"
         style="display:none;"></div>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Activar selector de DNI/CE
            initDocTypeToggle();

            // Validación básica en submit
            const form = document.getElementById('activateForm');
            const btnActivate = document.getElementById('btnActivate');
            const inputDoc = document.getElementById('inputDocumento');

            if (form && btnActivate && inputDoc) {
                form.addEventListener('submit', function (e) {
                    if (inputDoc.value.trim() === '') {
                        e.preventDefault();
                        const wrapper = inputDoc.closest('.input-group-custom');
                        if (wrapper) wrapper.classList.add('is-invalid');
                        inputDoc.focus();
                        return;
                    }

                    const btnText = btnActivate.querySelector('.btn-login-text');
                    const btnSpinner = btnActivate.querySelector('.btn-login-spinner');
                    if (btnText) btnText.classList.add('d-none');
                    if (btnSpinner) btnSpinner.classList.remove('d-none');
                    btnActivate.disabled = true;
                });

                // Limpiar error al escribir
                inputDoc.addEventListener('input', function () {
                    const wrapper = this.closest('.input-group-custom');
                    if (wrapper && this.value.trim() !== '') {
                        wrapper.classList.remove('is-invalid');
                    }
                });
            }

            // Mostrar toast si hay error
            var toastData = document.getElementById('activateToastData');
            if (toastData) {
                showToast(toastData.dataset.message, toastData.dataset.type);
            }
        });
    </script>
}
