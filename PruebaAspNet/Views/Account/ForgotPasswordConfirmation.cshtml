@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Instrucciones Enviadas";
    var email = ViewData["Email"] as string ?? "usuario@ceplan.gob.pe";
}

<div class="activated-container">
    <div class="activated-card animate-fade-in">
        <!-- Ilustración del cohete o check -->
        <div class="activated-rocket-container" style="background-color: #E8F3FF; border-radius: 50%; width: 100px; height: 100px; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 24px;">
            <i class="bi bi-send-check-fill" style="font-size: 48px; color: #006DDB;"></i>
        </div>

        <!-- Título -->
        <h1 class="activated-title">Instrucciones Enviadas</h1>

        <!-- Texto descriptivo -->
        <p class="activated-text" style="max-width: 320px; margin: 0 auto 24px auto;">
            Se ha enviado un mensaje con los pasos para restablecer su contraseña al correo registrado:<br />
            <strong>@email</strong>
        </p>

        <!-- Botón de acción principal -->
        <a href="/Account/Login" class="btn-activated-login">Volver al Inicio</a>
    </div>
</div>
